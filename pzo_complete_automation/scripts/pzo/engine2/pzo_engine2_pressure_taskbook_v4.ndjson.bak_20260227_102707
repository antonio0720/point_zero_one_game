/adam/Projects/adam/point_zero_one_master/pzo-web/src/engines/pressure/PressureSignalCollector.ts","notes":"[num_predict=2048] DEFECT FIX: setWeights() had no safety rails. A bad weight (negative, NaN, 9999) would silently corrupt every score computation. Fix: add a guard and a normalization utility.\n\nAPPEND before class declaration:\n\n/**\n * Validate that all weight fields are finite numbers in range [0, 1].\n * Throws RangeError on first invalid field.\n */\nexport function validateWeights(w: PressureSignalWeights): void {\n  for (const [key, val] of Object.entries(w) as [keyof PressureSignalWeights, number][]) {\n    if (!Number.isFinite(val) || val < 0 || val > 1) {\n      throw new RangeError(\n        `PressureSignalWeights.${key} = ${val} is out of range [0, 1] or non-finite.`\n      );\n    }\n  }\n}\n\n/** Keys of the 7 positive (pressure-increasing) signals. */\nconst POSITIVE_SIGNAL_KEYS: ReadonlyArray<keyof PressureSignalWeights> = [\n  'cashflowNegative','lowCashBalance','haterHeatHigh','activeThreatCards',\n  'lowShieldIntegrity','stagnationTax','activeCascadeChains',\n] as const;\n\n/**\n * Returns a new PressureSignalWeights with positive signals normalized to sum=1.0.\n * Negative reduction signals (prosperityBonus, fullSecurityBonus) are preserved as-is.\n * Safe to call with DEFAULT_SIGNAL_WEIGHTS to produce a normalized baseline.\n */\nexport function normalizePositiveWeights(\n  w: PressureSignalWeights\n): PressureSignalWeights {\n  const positiveSum = POSITIVE_SIGNAL_KEYS.reduce((acc, k) => acc + w[k], 0);\n  if (positiveSum === 0) return { ...w }; // guard: all zeros stays all zeros\n  const result = { ...w };\n  for (const k of POSITIVE_SIGNAL_KEYS) {\n    (result as any)[k] = w[k] / positiveSum;\n  }\n  return result;\n}\n\n// In setWeights() — add validation call:\npublic setWeights(weights: Partial<PressureSignalWeights>): void {\n  const merged = { ...this.weights, ...weights };\n  validateWeights(merged); // throws RangeError before