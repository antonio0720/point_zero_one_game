pzo_complete_automation/docs/pzo1/runtime/
**/artifacts/
**/bundles/
logs/
*.log

# -------------------------
# BUILD / CACHE
# -------------------------
**/target/
node_modules/
.next/
dist/
build/
coverage/
.turbo/
.vercel/
__pycache__/
*.pyc

# -------------------------
# DATABASE
# -------------------------
*.sqlite
*.db

# -------------------------
# OS
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# IDE / EDITOR
# -------------------------
.vscode/*
!.vscode/settings.json
.idea/
frontend/packages/engine/dist/
frontend/packages/engine/node_modules/
