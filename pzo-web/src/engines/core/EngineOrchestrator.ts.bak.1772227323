import type EventBus from '../../time/EventBus';
import { PressureEngine, DEFAULT_SIGNAL_WEIGHTS } from '../../engines/pressure';
import pressureStoreHandlers from '../../store/engineStore';
import DecisionTimer from './DecisionTimer';
import type TimeEngine from '../../time/TimeEngine';

type PressureReadInput = {
  monthlyIncome: number;
  monthlyExpenses: number;
  cashBalance: number;
  haterHeat: number;
  activeThreatCardCount: number;
  shieldIntegrityPct: number;
  ticksWithoutIncomeGrowth: number;
  activeCascadeChainCount: number;
  netWorth: number;
  freedomThreshold: number;
};

export class EngineOrchestrator {
  private eventBus: EventBus;
  private pressureEngine: PressureEngine;
  private decisionTimer: DecisionTimer;
  private timeEngine: TimeEngine | null = null;

  constructor(eventBus: EventBus) {
    this.eventBus = eventBus;
    this.pressureEngine = new PressureEngine(DEFAULT_SIGNAL_WEIGHTS);
    this.decisionTimer = new DecisionTimer();
    
    this.eventBus.on('PRESSURE_SCORE_UPDATED', (event) => {
      pressureStoreHandlers.onScoreUpdated(engineStore.set, event.payload);
    });
    
    this.eventBus.on('PRESSURE_TIER_CHANGED', (event) => {
      pressureStoreHandlers.onTierChanged(engineStore.set, event.payload);
    });
  }

  buildPressureInput(runSnapshot: any): PressureReadInput {
    return {
      monthlyIncome: runSnapshot.playerState.monthlyIncome,
      monthlyExpenses: runSnapshot.playerState.monthlyExpenses,
      cashBalance: runSnapshot.playerState.cashBalance,
      haterHeat: runSnapshot.playerState.haterHeat,
      activeThreatCardCount: runSnapshot.playerState.activeThreatCardCount,
      shieldIntegrityPct: runSnapshot.shieldState.shieldIntegrityPct,
      ticksWithoutIncomeGrowth: runSnapshot.playerState.ticksWithoutIncomeGrowth,
      activeCascadeChainCount: runSnapshot.cascadeState.activeCascadeChainCount,
      netWorth: runSnapshot.playerState.netWorth,
      freedomThreshold: runSnapshot.playerState.freedomThreshold,
    };
  }
}
