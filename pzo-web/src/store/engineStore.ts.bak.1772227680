export const pressureStoreHandlers = {
  onScoreUpdated(set: Function, event: PressureScoreUpdatedEvent) {
    set((state: any) => {
      state.pressure.score = event.score;
      state.pressure.currentTier = event.tier;
      state.pressure.signalBreakdown = event.signalBreakdown;
    });
  },
  onTierChanged(set: Function, event: PressureTierChangedEvent) {
    set((state: any) => {
      state.pressure.currentTier = event.to;
      state.pressure.previousTier = event.from;
      state.pressure.tierChangedThisTick = true;
      state.pressure.isEscalating = event.isEscalating;
    });
  },
  onSnapshotAvailable(set: Function, snapshot: PressureSnapshot, ticksToCalm: number) {
    set((state: any) => {
      state.pressure.score = snapshot.score;
      state.pressure.rawScore = snapshot.rawScore;
      state.pressure.currentTier = snapshot.tier;
      state.pressure.previousTier = snapshot.previousTier;
      state.pressure.tierChangedThisTick = snapshot.tierChangedThisTick;
      state.pressure.scoreHistory = [...snapshot.scoreHistory];
      state.pressure.isEscalating = snapshot.isEscalating;
      state.pressure.isDecaying = snapshot.isDecaying;
      state.pressure.dominantSignal = snapshot.dominantSignal;
      state.pressure.signalBreakdown = { ...snapshot.signalBreakdown };
      state.pressure.ticksToCalm = ticksToCalm;
    });
  },
  onRunStarted(set: Function) {
    set((state: any) => {
      Object.assign(state.pressure, { ...defaultPressureSlice.pressure, isRunActive: true });
    });
  },
  onRunEnded(set: Function) {
    set((state: any) => { state.pressure.isRunActive = false; });
  },
  onTickComplete(set: Function) {
    set((state: any) => { state.pressure.tierChangedThisTick = false; });
  },
};
