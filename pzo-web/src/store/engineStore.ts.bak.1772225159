import { create, setLazyGetDerivedStateFromProps } from 'zustand';

interface PressureTierChangedEventPayload {
    tier: string; // or any other relevant type for the pressure tier level.
}

interface PressureScoreUpdatedEventPayload {
    score: number; // Assuming a numerical representation of the current pressure score.
}

interface PressureCriticalEnteredEventPayload {
    criticalLevelsReached: boolean; // Indicates if any critical levels have been reached during this event.
}

// Discriminated union for all possible events that can occur within our store's context related to pressure changes.
export type PressureEvent = 
    | 'tierChanged' & { payload: PressureTierChangedEventPayload };
    | 'scoreUpdated' & { payload: PressureScoreUpdatedEventPayload };
    | 'criticalEntered' & { payload: PressureCriticalEnteredEventPayload };
    
// Store definition using Zustand with derived state for decisionWindowRemainingMs.
export const useTimeEngineStore = create<{ 
    decisionWindowRemainingMs: Record<string, number>; // Maps window IDs to their remaining milliseconds until the next tick of a countdown timer (e.g., when it's time to make decisions).
} & {
    onDecisionWindowTick(ticks: Record<string, number>): void; 
    clearDecisionWindowTick(windowId: string): void; // Clears the specified window from our map of remaining milliseconds.
    resetDecisionWindows(): void; // Resets all windows to zero time left until next tick (useful for a fresh start or when no decisions are pending).
}>(({ decisionWindowRemainingMs }) => ({ 
    onDecisionWindowTick: setLazyGetDerivedStateFromProps(
        () => { return decisionWindowRemainingMs; }, // Derived state from props.
        (state, ticks) => { const current = state.decisionWindowRemainingMs; let changed = false; for (const [id, ms] of Object.entries(ticks)) if (current[id] !== ms) { changed = true; break; } return !changed ? state : ({ decisionWindowRemainingMs: { ...state.decisionWindowRemainingMs, ...ticks } }); },
        () => {}, // No props to derive from for this store as it's internal and not exposed externally.
    ), 
    clearDecisionWindowTick: (windowId) => setLazyGetDerivedStateFromProps(
        () => decisionWindowRemainingMs,
        ({ decisionWindowRemainingMs }) => { const next = { ...decisionWindowRemainingMs }; delete next[windowId]; return { decisionWindowRemainingMs: next }; }, 
    ), 
    resetDecisionWindows: (state) => setLazyGetDerivedStateFromProps(
        () => ({ decisionWindowRemainingMs: {} }), // Derived state from props. Always returns the initial value for this derived store as it'self is not exposed externally and doesn't have any external dependencies to derive its own internal state from. 
    ),
}));
